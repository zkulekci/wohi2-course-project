generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Questions {
  id        Int       @id @default(autoincrement())
  question  String    @db.VarChar(255)
  answer    String    @db.VarChar(255)
  keywords  Keyword[]

  @@map("questions")
}

model Keyword {
  id    Int    @id @default(autoincrement())
  name  String @unique @db.VarChar(100)
  questions Questions[]

  @@map("keywords")
}